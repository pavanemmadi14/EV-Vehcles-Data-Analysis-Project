      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0xqtgfn1hu21n71auy5ob0d1uiiz].[pcto:usr:Calculation_1721875084570624:qk]&quot;' value='% of Total' />
        </aliases>
      </column>
      <column caption='Total Vehicles' datatype='integer' name='[Calculation_1721875084570624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([DOL Vehicle ID])' />
      </column>
      <column caption='Avg Electric Range' datatype='real' name='[Calculation_1721875086036993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Electric Range])' />
      </column>
      <column caption='Total BEV Vehicles' datatype='integer' name='[Calculation_1721875088482306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD( IF [Electric Vehicle Type]=&quot;Battery Electric Vehicle (BEV)&quot;&#13;&#10; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='% of Total BEV Vehicles' datatype='real' name='[Calculation_1721875089489923]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1721875088482306] / [Calculation_1721875084570624]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_1721875093458948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Electric Vehicle Type]= &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='% of Total PHEV Vehicles' datatype='real' name='[Calculation_1721875093966853]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1721875093458948] / [Calculation_1721875084570624]' />
